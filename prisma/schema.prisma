// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum EventType {
  TICKET
  FORM
}

enum BookingStatus {
  // --- คิว ---
  WAITING_QUEUE_APPROVAL    // 1.  รอแอดมินอนุมัติคิว
  WAITING_DEPOSIT_TRANSFER  // 2.  รอโอนมัดจำ
  WAITING_DEPOSIT_VERIFY    // 3.  รอตรวจสลิปมัดจำ
  QUEUE_BOOKED              // 4.  จองคิวสำเร็จ
  WAITING_BOOKING_INFO      // 5.  รอกรอกข้อมูลจอง
  TRANSFERRING_TICKET       // 6.  โอนค่าบัตร (กรณีฝากร้าน)
  CONFIRMING_TICKET         // 7.  ยืนยันโอนค่าบัตร
  WAITING_ADMIN_CONFIRM     // 8.  รอแอดมินยืนยันข้อมูล
  READY_TO_BOOK             // 9.  พร้อมกดบัตร

  // --- ระหว่างกด ---
  BOOKING_IN_PROGRESS       // 10. กำลังกดบัตร
  PARTIALLY_BOOKED          // 11. ได้บัตรบางส่วน
  FULLY_BOOKED              // 12. กดได้ครบแล้ว
  BOOKING_FAILED            // 13. กดไม่ได้

  // --- ลูกค้าได้เอง ---
  CUSTOMER_SELF_BOOKED      // 14. ลูกค้าแจ้งว่าได้เอง (รอทีมตรวจ)
  TEAM_NOT_RECEIVED         // 15. ทีมยังไม่ได้บัตร
  TEAM_BOOKED               // 16. ทีมกดได้แล้ว
  PARTIAL_SELF_TEAM_BOOKING // 17. ลูกค้าได้เองบางส่วน / ทีมกดต่อ

  // --- การเงิน ---
  WAITING_SERVICE_FEE       // 18. รอโอนค่ากด
  WAITING_SERVICE_FEE_VERIFY // 19. รอตรวจสลิปค่ากด
  SERVICE_FEE_PAID          // 20. ชำระค่ากดแล้ว

  // --- มัดจำ ---
  DEPOSIT_PENDING           // 21. รอใช้งาน
  DEPOSIT_USED              // 22. ใช้เป็นค่ากด
  DEPOSIT_FORFEITED         // 23. ยึดมัดจำ
  WAITING_REFUND            // 24. รอคืนเงิน
  REFUNDED                  // 25. โอนคืนแล้ว

  // --- ปิดงาน ---
  COMPLETED                 // 26. เสร็จสมบูรณ์
  CANCELLED                 // 27. ยกเลิก (ยึดมัดจำ)
  CLOSED_REFUNDED           // 28. ปิดงาน (คืนเงินแล้ว)
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentSlipType {
  DEPOSIT_PAID   // ชำระค่ามัดจำ
  CARD_PAID      // ชำระค่าบัตร
  SERVICE_PAID   // ชำระค่ากด
}

enum PaymentSlipStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum FulfillmentType {
  ETICKET
  PICKUP
  DELIVERY
}

enum DeliveryStatus {
  NOT_STARTED
  WAITING_PICKUP
  READY_FOR_PICKUP
  PICKED_UP
  WAITING_DELIVERY
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DepositTransactionType {
  HELD
  USED
  FORFEITED
  REFUNDED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  firstName  String
  lastName   String
  line       String?
  phone      String?
  role       AdminRole @default(ADMIN)
  lastLogin  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  activities ActivityLog[]
  paymentSlipsReviewed PaymentSlip[] @relation("reviewer")
  statusLogsChanged    BookingStatusLog[]
  refundsProcessed     RefundRequest[]
  refundStatusLogs     RefundRequestLog[] @relation("refundStatusLogs")
  paymentSlipLogs      PaymentSlipLog[]   @relation("paymentSlipLogs")


  @@map("users")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  nickname  String?
  email     String?
  phone     String?
  lineId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]

  @@map("customers")
}

model Event {
  id           Int      @id @default(autoincrement())
  name         String
  notes        String?
  posterUrl    String?
  posterImage  String?
  type         EventType

  eventDate    DateTime?

  feePerEntry  Decimal?
  capacity     Int?

  isActive     Boolean  @default(true)
  status       Boolean  @default(true)

  // relations
  showRounds       ShowRound[]
  deepInfoFields   DeepInfoField[]
  bookings         Booking[]
  deposits         DepositTransaction[]

  // audit
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?
}

model ShowRound {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime
  time      String

  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  zones        Zone[]
  bookingItems BookingItem[]

  createdAt DateTime @default(now())
}

model Zone {
  id        Int      @id @default(autoincrement())
  name      String

  price     Decimal
  fee       Decimal
  capacity  Int

  roundId   Int
  round     ShowRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  bookingItems BookingItem[]

  createdAt DateTime @default(now())
}

model DeepInfoField {
  id         Int      @id @default(autoincrement())
  otherCode  String
  label      String
  isRequired Boolean  @default(false)

  eventId    Int
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  responses  DeepInfoResponse[]

  createdAt  DateTime @default(now())
}


model Booking {
  id              Int           @id @default(autoincrement())
  queueCode       String        @unique
  bookingCode     String        @unique
  eventId         Int
  customerId      Int
  nameCustomer    String?
  status          BookingStatus @default(WAITING_QUEUE_APPROVAL)
  paymentStatus   PaymentStatus @default(UNPAID)
  netCardPrice    Float         @default(0)
  serviceFee      Float         @default(0)
  shippingFee     Float         @default(0)
  vatAmount       Float         @default(0)
  depositPaid     Float         @default(0)
  totalPaid       Float         @default(0)
  refundAmount    Float         @default(0)
  isActive        Boolean      @default(true)
  notes           String?

  // audit
  createdAt       DateTime      @default(now())
  createdBy       String?
  updatedAt       DateTime      @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?

  event            Event              @relation(fields: [eventId], references: [id])
  customer         Customer           @relation(fields: [customerId], references: [id])
  paymentSlips     PaymentSlip[]
  fulfillment      Fulfillment?
  statusLogs       BookingStatusLog[]
  billingRecord    BillingRecord?
  refunds          RefundRequest[]
  deposits         DepositTransaction[]
  formSubmission   FormSubmission?
  bookingItems     BookingItem[]
  deepInfoResponses DeepInfoResponse[]

  @@map("bookings")
}

model PaymentSlip {
  id           Int               @id @default(autoincrement())
  bookingId    Int
  reviewerId   Int?
  type         PaymentSlipType
  status       PaymentSlipStatus @default(PENDING)
  systemAmount Float
  slipAmount   Float
  imageUrl     String
  reviewedAt   DateTime?
  notes        String?
  createdAt    DateTime          @default(now())

  booking    Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer   User?             @relation("reviewer", fields: [reviewerId], references: [id])
  statusLogs PaymentSlipLog[]

  @@map("payment_slips")
}

model PaymentSlipLog {
  id           Int               @id @default(autoincrement())
  paymentSlipId Int
  changedById  Int
  status       PaymentSlipStatus
  note         String?
  createdAt    DateTime          @default(now())

  paymentSlip PaymentSlip @relation(fields: [paymentSlipId], references: [id], onDelete: Cascade)
  changedBy   User        @relation("paymentSlipLogs", fields: [changedById], references: [id])

  @@map("payment_slip_logs")
}

model BillingRecord {
  id            Int           @id @default(autoincrement())
  bookingId     Int           @unique
  billNumber    String        @unique
  subtotal      Float         @default(0)
  serviceFee    Float         @default(0)
  shippingFee   Float         @default(0)
  vatRate       Float         @default(0.07)
  vatAmount     Float         @default(0)
  totalDue      Float         @default(0)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("billing_records")
}

model DepositTransaction {
  id        Int                    @id @default(autoincrement())
  bookingId Int?
  eventId   Int?
  type      DepositTransactionType
  amount    Float
  notes     String?
  createdAt DateTime               @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id])
  event   Event?   @relation(fields: [eventId], references: [id])

  @@map("deposit_transactions")
}

model RefundRequest {
  id            Int          @id @default(autoincrement())
  bookingId     Int
  processedById Int?
  bookingRef    String?
  bankName      String
  accountNumber String
  accountHolder String
  amount        Float
  status        RefundStatus @default(REQUESTED)
  reason        String?
  requestedAt   DateTime     @default(now())
  processedAt   DateTime?

  booking     Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  processedBy User?                @relation(fields: [processedById], references: [id])
  statusLogs  RefundRequestLog[]

  @@map("refund_requests")
}

model RefundRequestLog {
  id              Int          @id @default(autoincrement())
  refundRequestId Int
  changedById     Int
  status          RefundStatus
  note            String?
  createdAt       DateTime     @default(now())

  refundRequest RefundRequest @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)
  changedBy     User          @relation("refundStatusLogs", fields: [changedById], references: [id])

  @@map("refund_request_logs")
}

model Fulfillment {
  id              Int             @id @default(autoincrement())
  bookingId       Int             @unique
  type            FulfillmentType
  deliveryStatus  DeliveryStatus  @default(NOT_STARTED)
  pickupDateTime  DateTime?
  pickupLocation  String?
  qrCode          String?
  shippingAddress String?
  shippingCity    String?
  shippingPostal  String?
  recipientName   String?
  recipientPhone  String?
  trackingNumber  String?
  shippingFee     Float?          @default(0)
  serviceFee      Float?          @default(0)
  vatAmount       Float?          @default(0)
  totalCharge     Float?          @default(0)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("fulfillments")
}

model BookingStatusLog {
  id        Int           @id @default(autoincrement())
  bookingId Int
  changedBy Int
  status    BookingStatus
  notes     String?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  admin   User    @relation(fields: [changedBy], references: [id])

  @@map("booking_status_logs")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  entityType String
  entityId   Int?
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// รายการบัตร/สินค้าที่จองในแต่ละ booking (รองรับทั้ง TICKET และ FORM)
model BookingItem {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  roundId     Int?     // สำหรับ TICKET: รอบที่เลือก
  zoneId      Int?     // สำหรับ TICKET: โซนที่เลือก
  quantity    Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())

  booking Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  round   ShowRound? @relation(fields: [roundId], references: [id])
  zone    Zone?      @relation(fields: [zoneId], references: [id])

  @@map("booking_items")
}

// เก็บคำตอบของ deepInfoFields ที่ผู้ใช้กรอก (ใช้ได้ทั้ง TICKET และ FORM)
model DeepInfoResponse {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  fieldId     Int
  value       String   // ค่าที่ผู้ใช้กรอก
  createdAt   DateTime @default(now())

  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  field   DeepInfoField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([bookingId, fieldId])
  @@map("deep_info_responses")
}

model FormSubmission {
  id          Int      @id @default(autoincrement())
  bookingId   Int      @unique
  formData    Json
  submittedAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}
