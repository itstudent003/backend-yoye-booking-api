// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
  PRESSER
}

enum EventType {
  TICKET
  FORM
}

enum BookingStatus {
  // --- คิว ---
  WAITING_QUEUE_APPROVAL    // 1.  รอแอดมินอนุมัติคิว
  WAITING_DEPOSIT_TRANSFER  // 2.  รอโอนมัดจำ
  WAITING_DEPOSIT_VERIFY    // 3.  รอตรวจสลิปมัดจำ
  QUEUE_BOOKED              // 4.  จองคิวสำเร็จ
  WAITING_BOOKING_INFO      // 5.  รอกรอกข้อมูลจอง
  TRANSFERRING_TICKET       // 6.  โอนค่าบัตร (กรณีฝากร้าน)
  CONFIRMING_TICKET         // 7.  ยืนยันโอนค่าบัตร
  WAITING_ADMIN_CONFIRM     // 8.  รอแอดมินยืนยันข้อมูล
  READY_TO_BOOK             // 9.  พร้อมกดบัตร

  // --- ระหว่างกด ---
  BOOKING_IN_PROGRESS       // 10. กำลังกดบัตร
  PARTIALLY_BOOKED          // 11. ได้บัตรบางส่วน
  FULLY_BOOKED              // 12. กดได้ครบแล้ว
  BOOKING_FAILED            // 13. กดไม่ได้

  // --- ลูกค้าได้เอง ---
  CUSTOMER_SELF_BOOKED      // 14. ลูกค้าแจ้งว่าได้เอง (รอทีมตรวจ)
  TEAM_NOT_RECEIVED         // 15. ทีมยังไม่ได้บัตร
  TEAM_BOOKED               // 16. ทีมกดได้แล้ว
  PARTIAL_SELF_TEAM_BOOKING // 17. ลูกค้าได้เองบางส่วน / ทีมกดต่อ

  // --- การเงิน ---
  WAITING_SERVICE_FEE       // 18. รอโอนค่ากด
  WAITING_SERVICE_FEE_VERIFY // 19. รอตรวจสลิปค่ากด
  SERVICE_FEE_PAID          // 20. ชำระค่ากดแล้ว

  // --- มัดจำ ---
  DEPOSIT_PENDING           // 21. รอใช้งาน
  DEPOSIT_USED              // 22. ใช้เป็นค่ากด
  DEPOSIT_FORFEITED         // 23. ยึดมัดจำ
  WAITING_REFUND            // 24. รอคืนเงิน
  REFUNDED                  // 25. โอนคืนแล้ว

  // --- ปิดงาน ---
  COMPLETED                 // 26. เสร็จสมบูรณ์
  CANCELLED                 // 27. ยกเลิก (ยึดมัดจำ)
  CLOSED_REFUNDED           // 28. ปิดงาน (คืนเงินแล้ว)
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentSlipType {
  DEPOSIT_PAID   // ชำระค่ามัดจำ
  CARD_PAID      // ชำระค่าบัตร
  SERVICE_PAID   // ชำระค่ากด
}

enum PaymentSlipStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum FulfillmentType {
  ETICKET
  PICKUP
  DELIVERY
}

enum BillAction {
  CREATE
  EDIT
}

enum DeliveryStatus {
  NOT_STARTED
  WAITING_DELIVERY
  DELIVERED
  CANCELLED
}

enum DepositTransactionType {
  HELD
  USED
  FORFEITED
  REFUNDED
}

enum DepositStatus {
  DEPOSIT_PENDING
  DEPOSIT_USED
  DEPOSIT_FORFEITED
  WAITING_REFUND
  REFUNDED
}

enum DepositReason {
  PRESS_SUCCESS
  PRESS_FAILED
  CUSTOMER_CANCEL
  CUSTOMER_SELF_BOOKED
  ADMIN_OVERRIDE
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
}

enum RefundCategory {
  TICKET
  DEPOSIT
  PRICE_DIFF
  SHIPPING
  MIXED
}

enum ExpenseCategory {
  TRANSPORT
  EQUIPMENT
  FOOD
  SUBSCRIPTION
  OTHER
}

enum ExpensePaidBy {
  COMPANY
  TEAM
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ActivityType {
  BOOKING_STATUS_CHANGED
  SLIP_VERIFIED
  SLIP_REJECTED
  REFUND_REQUESTED
  REFUND_APPROVED
  REFUND_REJECTED
  REFUND_PAID
  DEPOSIT_OVERRIDE
  EXPENSE_SUBMITTED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  PRESSER_ASSIGNED
  PRESSER_VIEW_CREDENTIAL
  TICKET_RECORDED
  TICKET_VOIDED
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  firstName  String
  lastName   String
  line       String?
  phone      String?
  role       AdminRole @default(ADMIN)
  isActive   Boolean   @default(true)
  lastLogin  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  activities ActivityLog[] @relation("ActivityUser")
  activityLogs ActivityLog[] @relation("ActivityActor")
  paymentSlipsReviewed PaymentSlip[] @relation("reviewer")
  statusLogsChanged    BookingStatusLog[]
  requestedRefunds      RefundRequest[] @relation("Requested")
  processedRefunds      RefundRequest[] @relation("Processed")
  refundStatusLogs     RefundRequestLog[] @relation("refundStatusLogs")
  paymentSlipLogs      PaymentSlipLog[]   @relation("paymentSlipLogs")
  fulfillmentLogs      FulfillmentLog[]   @relation("fulfillmentLogs")
  pressedBookings       BookingPresser[]   @relation("PressedBookings")
  assignedByLogs        BookingPresser[]   @relation("AssignedBy")
  eventPressers         EventPresser[]      @relation("EventPressers")
  eventPresserAssignments EventPresser[]    @relation("EventPresserAssignedBy")
  pressedTickets        BookedTicket[]     @relation("PressedTickets")
  voidedTickets         BookedTicket[]     @relation("VoidedTickets")
  decidedDeposits       DepositTransaction[] @relation("DecidedDeposits")
  submittedExpenses     Expense[]          @relation("Submitted")
  approvedExpenses      Expense[]          @relation("Approved")


  @@map("users")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  nickname  String?
  email     String?
  phone     String?
  lineId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  credentials CustomerCredential[]

  @@map("customers")
}

model Event {
  id           Int      @id @default(autoincrement())
  name         String
  notes        String?
  posterUrl    String?
  posterImage  String?
  type         EventType

  eventDate    DateTime?

  feePerEntry  Decimal?
  capacity     Int?

  isActive     Boolean  @default(true)
  status       Boolean  @default(true)

  // relations
  showRounds       ShowRound[]
  deepInfoFields   DeepInfoField[]
  bookings         Booking[]
  deposits         DepositTransaction[]
  expenses         Expense[]
  pressers         EventPresser[]

  // audit
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?
}

model ShowRound {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime
  time      String

  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  zones        Zone[]
  bookingItems BookingItem[]

  createdAt DateTime @default(now())
}

model Zone {
  id        Int      @id @default(autoincrement())
  name      String

  price     Decimal
  fee       Decimal
  capacity  Int

  roundId   Int
  round     ShowRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  bookingItems BookingItem[]
  bookedTickets BookedTicket[]

  createdAt DateTime @default(now())
}

model DeepInfoField {
  id         Int      @id @default(autoincrement())
  otherCode  String
  label      String
  isRequired Boolean  @default(false)

  eventId    Int
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  responses  DeepInfoResponse[]

  createdAt  DateTime @default(now())
}


model Booking {
  id              Int           @id @default(autoincrement())
  bookingCode     String        @unique
  eventId         Int
  customerId      Int
  nameCustomer    String?
  status          BookingStatus @default(WAITING_QUEUE_APPROVAL)
  paymentStatus   PaymentStatus @default(UNPAID)
  netCardPrice    Float         @default(0)
  serviceFee      Float         @default(0)
  shippingFee     Float         @default(0)
  vatAmount       Float         @default(0)
  depositPaid     Float         @default(0)
  totalPaid       Float         @default(0)
  refundAmount    Float         @default(0)
  isActive        Boolean      @default(true)
  notes           String?

  // audit
  createdAt       DateTime      @default(now())
  createdBy       String?
  updatedAt       DateTime      @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?

  event            Event              @relation(fields: [eventId], references: [id])
  customer         Customer           @relation(fields: [customerId], references: [id])
  paymentSlips     PaymentSlip[]
  fulfillment      Fulfillment?
  statusLogs       BookingStatusLog[]
  billingRecord    BillingRecord?
  refunds          RefundRequest[]
  deposits         DepositTransaction[]
  pressers         BookingPresser[]
  bookedTickets    BookedTicket[]
  credentials      CustomerCredential[]
  expenses         Expense[]
  activityLogs     ActivityLog[]
  formSubmission   FormSubmission?
  bookingItems     BookingItem[]
  deepInfoResponses DeepInfoResponse[]

  @@map("bookings")
}

model PaymentSlip {
  id           Int               @id @default(autoincrement())
  bookingId    Int
  reviewerId   Int?
  type         PaymentSlipType
  status       PaymentSlipStatus @default(PENDING)
  systemAmount Float
  slipAmount   Float
  imageUrl     String
  reviewedAt   DateTime?
  notes        String?
  createdAt    DateTime          @default(now())

  booking    Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer   User?             @relation("reviewer", fields: [reviewerId], references: [id])
  statusLogs PaymentSlipLog[]
  refundRequests RefundRequest[]

  @@map("payment_slips")
}

model PaymentSlipLog {
  id           Int               @id @default(autoincrement())
  paymentSlipId Int
  changedById  Int
  status       PaymentSlipStatus
  note         String?
  createdAt    DateTime          @default(now())

  paymentSlip PaymentSlip @relation(fields: [paymentSlipId], references: [id], onDelete: Cascade)
  changedBy   User        @relation("paymentSlipLogs", fields: [changedById], references: [id])

  @@map("payment_slip_logs")
}

model BillingRecord {
  id            Int           @id @default(autoincrement())
  bookingId     Int           @unique
  billNumber    String        @unique
  subtotal      Float         @default(0)
  serviceFee    Float         @default(0)
  shippingFee   Float         @default(0)
  vatRate       Float         @default(0.07)
  vatAmount     Float         @default(0)
  totalDue      Float         @default(0)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("billing_records")
}

model DepositTransaction {
  id        Int                    @id @default(autoincrement())
  bookingId Int?
  eventId   Int?
  type      DepositTransactionType
  amount    Float
  status          DepositStatus?
  usedAmount      Decimal?      @db.Decimal(10, 2)
  refundAmount    Decimal?      @db.Decimal(10, 2)
  forfeitedAmount Decimal?      @db.Decimal(10, 2)
  reason          DepositReason?
  reasonNotes     String?
  decidedById     Int?
  decidedAt       DateTime?
  notes     String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id])
  event   Event?   @relation(fields: [eventId], references: [id])
  decidedBy User?  @relation("DecidedDeposits", fields: [decidedById], references: [id])

  @@index([status])
  @@map("deposit_transactions")
}

model RefundRequest {
  id            Int          @id @default(autoincrement())
  bookingId     Int
  paymentSlipId Int?
  processedById Int?
  requestedById Int?
  bookingRef    String?
  bankName      String
  accountNumber String
  accountHolder String
  amount        Float
  status        RefundStatus @default(REQUESTED)
  category      RefundCategory @default(MIXED)
  breakdown     Json?
  reason        String?
  rejectionNote String?
  payoutSlipUrl String?
  paidAt        DateTime?
  requestedAt   DateTime     @default(now())
  processedAt   DateTime?

  booking     Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentSlip PaymentSlip?         @relation(fields: [paymentSlipId], references: [id])
  requestedBy User?                @relation("Requested", fields: [requestedById], references: [id])
  processedBy User?                @relation("Processed", fields: [processedById], references: [id])
  statusLogs  RefundRequestLog[]

  @@index([status])
  @@index([bookingId])
  @@map("refund_requests")
}

model RefundRequestLog {
  id              Int          @id @default(autoincrement())
  refundRequestId Int
  changedById     Int
  status          RefundStatus
  note            String?
  createdAt       DateTime     @default(now())

  refundRequest RefundRequest @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)
  changedBy     User          @relation("refundStatusLogs", fields: [changedById], references: [id])

  @@map("refund_request_logs")
}

model Fulfillment {
  id              Int             @id @default(autoincrement())
  bookingId       Int             @unique
  type            FulfillmentType
  deliveryStatus  DeliveryStatus  @default(NOT_STARTED)
  pickupDateTime  DateTime?
  pickupLocation  String?
  qrCode          String?
  shippingAddress String?
  shippingCity    String?
  shippingPostal  String?
  recipientName   String?
  recipientPhone  String?
  trackingNumber  String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  booking  Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  billLogs FulfillmentLog[]

  @@map("fulfillments")
}

model FulfillmentLog {
  id              Int             @id @default(autoincrement())
  fulfillmentId   Int
  adminId         Int
  action          BillAction
  fulfillmentType FulfillmentType
  serviceFee      Float
  shippingFee     Float
  vatAmount       Float
  vatServiceFee   Float   @default(0)
  vatShippingFee  Float   @default(0)
  totalCharge     Float
  note            String?
  createdAt       DateTime        @default(now())

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  admin       User        @relation("fulfillmentLogs", fields: [adminId], references: [id])

  @@map("fulfillment_logs")
}

model BookingStatusLog {
  id        Int           @id @default(autoincrement())
  bookingId Int
  changedBy Int
  status    BookingStatus
  notes     String?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  admin   User    @relation(fields: [changedBy], references: [id])

  @@map("booking_status_logs")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  actorId    Int?
  entityType String?
  entity     String?
  entityId   Int?
  action     String
  type       ActivityType?
  metadata   Json?
  bookingId  Int?
  bookingCode String?
  message    String?
  createdAt  DateTime @default(now())

  user User? @relation("ActivityUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("ActivityActor", fields: [actorId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([entity, entityId])
  @@index([bookingId])
  @@index([createdAt])
  @@map("activity_logs")
}

model BookingPresser {
  bookingId      Int
  presserId      Int
  assignedAt     DateTime @default(now())
  assignedBy     Int
  notes          String?
  deletedAt      DateTime?
  deletedBy      Int?

  booking        Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  presser        User    @relation("PressedBookings", fields: [presserId], references: [id])
  assignedByUser User    @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@id([bookingId, presserId])
  @@index([presserId])
  @@index([deletedAt])
  @@map("booking_pressers")
}

model EventPresser {
  eventId        Int
  presserId      Int
  assignedAt     DateTime @default(now())
  assignedBy     Int
  notes          String?
  deletedAt      DateTime?
  deletedBy      Int?

  event          Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  presser        User  @relation("EventPressers", fields: [presserId], references: [id])
  assignedByUser User  @relation("EventPresserAssignedBy", fields: [assignedBy], references: [id])

  @@id([eventId, presserId])
  @@index([presserId])
  @@index([deletedAt])
  @@map("event_pressers")
}

model BookedTicket {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  zoneId      Int?
  zoneNameRaw String
  seat        String
  price       Decimal  @db.Decimal(10, 2)
  pressedById Int
  pressedAt   DateTime @default(now())
  notes       String?
  voidedAt    DateTime?
  voidedById  Int?

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  zone      Zone?   @relation(fields: [zoneId], references: [id])
  pressedBy User    @relation("PressedTickets", fields: [pressedById], references: [id])
  voidedBy  User?   @relation("VoidedTickets", fields: [voidedById], references: [id])

  @@index([bookingId])
  @@map("booked_tickets")
}

model Expense {
  id             Int             @id @default(autoincrement())
  bookingId      Int?
  eventId        Int?
  category       ExpenseCategory
  description    String
  amount         Decimal         @db.Decimal(10, 2)
  paidBy         ExpensePaidBy
  receiptUrl     String?
  status         ExpenseStatus   @default(PENDING)
  submittedById  Int
  submittedAt    DateTime        @default(now())
  approvedById   Int?
  approvedAt     DateTime?
  rejectedNote   String?
  settledAt      DateTime?
  settlementNote String?

  booking     Booking? @relation(fields: [bookingId], references: [id])
  event       Event?   @relation(fields: [eventId], references: [id])
  submittedBy User     @relation("Submitted", fields: [submittedById], references: [id])
  approvedBy  User?    @relation("Approved", fields: [approvedById], references: [id])

  @@index([status])
  @@index([submittedById])
  @@map("expenses")
}

model CustomerCredential {
  id                Int      @id @default(autoincrement())
  customerId        Int
  bookingId         Int?
  site              String
  username          String
  passwordEncrypted String
  notes             String?
  createdAt         DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([customerId])
  @@map("customer_credentials")
}

// รายการบัตร/สินค้าที่จองในแต่ละ booking (รองรับทั้ง TICKET และ FORM)
model BookingItem {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  roundId     Int?     // สำหรับ TICKET: รอบที่เลือก
  zoneId      Int?     // สำหรับ TICKET: โซนที่เลือก
  quantity    Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())

  booking Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  round   ShowRound? @relation(fields: [roundId], references: [id])
  zone    Zone?      @relation(fields: [zoneId], references: [id])

  @@map("booking_items")
}

// เก็บคำตอบของ deepInfoFields ที่ผู้ใช้กรอก (ใช้ได้ทั้ง TICKET และ FORM)
model DeepInfoResponse {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  fieldId     Int
  value       String   // ค่าที่ผู้ใช้กรอก
  createdAt   DateTime @default(now())

  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  field   DeepInfoField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([bookingId, fieldId])
  @@map("deep_info_responses")
}

model FormSubmission {
  id          Int      @id @default(autoincrement())
  bookingId   Int      @unique
  formData    Json
  submittedAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}
